      "item": [
        {
          "name": "Get Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is under 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains users\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data.length).to.be.above(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 10 users\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data.length).to.eql(10);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"First user has email field\", function () {\r",
                  "    const data = pm.response.json();\r",
                  "    pm.expect(data[0]).to.have.property(\"email\");\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
